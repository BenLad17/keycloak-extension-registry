{
	"name": "keycloak-extension-registry",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node cron/append.js",
		"preview": "vite preview",
		"deploy": "npm run db:migrate && wrangler deploy",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ../tsconfig.json --workspace src",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ../tsconfig.json --workspace src --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"types": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply keycloak-extension-registry --remote",
		"db:migrate:local": "wrangler d1 migrations apply keycloak-extension-registry --local",
		"db:studio": "drizzle-kit studio",
		"test": "svelte-kit sync && vitest run"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24.10.13",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.1",
		"wrangler": "^4.63.0"
	},
	"dependencies": {
		"fflate": "^0.8.2",
		"highlight.js": "^11.11.1",
		"jose": "^6.1.3",
		"lucide-svelte": "^0.575.0",
		"marked": "^17.0.3",
		"node-emoji": "^2.2.0",
		"octokit": "^5.0.5",
		"uuid": "^13.0.0",
		"yaml": "^2.8.2",
		"zod": "^4.3.6"
	}
}

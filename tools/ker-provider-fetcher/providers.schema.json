{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KER Providers Config",
  "type": "object",
  "required": ["providers"],
  "properties": {
    "registry_url": {
      "type": "string",
      "description": "Base URL of the Keycloak Extension Registry"
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version"],
        "properties": {
          "name":    { "type": "string", "description": "Extension slug from the registry" },
          "version": { "type": "string", "description": "Version tag (e.g. v1.2.0)" },
          "sha256":  { "type": "string", "description": "Expected SHA-256 checksum (hex)" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

# Database
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# GitHub App (create at https://github.com/settings/apps)
# Callback URL: http://localhost:5173/api/auth/callback
# Webhook URL: https://your-domain.com/api/webhooks/github
# Permissions needed:
#   - Repository: Contents (read), Metadata (read)
#   - Account: Email addresses (read)
GITHUB_APP_ID="your-app-id"
GITHUB_APP_SLUG="keycloak-extension-registry"
GITHUB_CLIENT_ID="your-client-id"
GITHUB_CLIENT_SECRET="your-client-secret"
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET="your-webhook-secret"

# JWT Secret for session tokens
JWT_SECRET="change-this-to-a-random-string"

# Registry URL
REGISTRY_URL="http://localhost:5173"
